{
  "name": "electron-vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Daniel Parsons",
  "description": "Electron + React + native-process starter template.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac dmg",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "lint": "eslint . --ext ts,tsx --rulesdir eslint-rules --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --rulesdir eslint-rules --max-warnings 0"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.75.7",
    "better-sqlite3": "^12.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-toastify": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript": "~5.5.4",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9"
  },
  "main": "dist-electron/main.js"
}
